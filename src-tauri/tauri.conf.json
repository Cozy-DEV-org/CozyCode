{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "CozyCode",
	"version": "0.6.1",
	"identifier": "com.cozycode.app",
	"build": {
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "CozyCode",
				"width": 1280,
				"height": 800,
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": ["icons/icon.ico"]
	}
}
