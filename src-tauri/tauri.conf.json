{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "CozyCode",
	"version": "0.8.2",
	"identifier": "com.cozycode.app",
	"build": {
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "CozyCode",
				"width": 1280,
				"height": 800,
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis", "msi"],
		"icon": ["icons/icon.ico"],
		"createUpdaterArtifacts": true,
		"publisher": "CozyDev",
		"shortDescription": "A cozy, lightweight code editor",
		"windows": {
			"nsis": {
				"installMode": "currentUser"
			}
		}
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/Cozy-DEV-org/CozyCode/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGREQyNjJEMDFFRkJGRTMKUldUanYrOEJMU2JkYjVtTlUvVThCbDA5Z2ZqMnNIOGxrVE83TkNPc1ZNL0V5cGpqTVFIM1dWalMK"
		}
	}
}
